<script>

  // ── Hash ↔ Section mapping ──

  const HASH_MAP = {

    home:      '#home',

    shop:      '#plans',

    myaccount: '#my-account'

  };

  const REVERSE_HASH = Object.fromEntries(

    Object.entries(HASH_MAP).map(([k, v]) => [v, k])

  );
 
  // ── Section Navigation (updates URL hash) ──

  const SECTIONS = ['home','shop','myaccount'];
 
  function showSection(name, skipHash) {

    SECTIONS.forEach(s => {

      document.getElementById('section-'+s).style.display = (s === name) ? '' : 'none';

    });

    SECTIONS.forEach(s => {

      const t = document.getElementById('tab-'+s);

      if (t) t.classList.remove('active');

    });

    const active = document.getElementById('tab-'+name);

    if (active) active.classList.add('active');

    window.scrollTo({top:0, behavior:'smooth'});

    if (name === 'shop') {

      setTimeout(() => {

        document.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));

      }, 80);

    }

    // Update URL hash without adding a history entry if skipHash is set

    if (!skipHash) {

      const hash = HASH_MAP[name] || '#home';

      history.replaceState(null, '', hash);

    }

  }
 
  // ── Cart (updates URL hash when items are added) ──

  let cart = [];
 
  function addToCart(name, price, icon, tier, btn) {

    if (cart.find(i => i.name === name)) { showToast(name+' is already in your cart!'); return; }

    cart.push({name, price, icon, tier});

    updateCart();

    btn.innerHTML = '✓ &nbsp;Added!';

    btn.classList.add('added');

    setTimeout(() => { btn.innerHTML = '🛒 &nbsp;Add to Cart'; }, 2000);

    showToast(name+' added ✓');

    // Reflect cart state in URL

    updateCartHash();

  }
 
  function removeFromCart(i) {

    cart.splice(i,1);

    updateCart();

    updateCartHash();

  }
 
  // Builds a URL hash that reflects the current plan + cart contents

  // e.g. #plans?cart=basic,gold

  function updateCartHash() {

    const currentHash = window.location.hash.split('?')[0] || '#plans';

    if (cart.length === 0) {

      // Remove cart query from hash if cart is empty

      history.replaceState(null, '', currentHash);

    } else {

      const tiers = cart.map(i => i.tier).join(',');

      history.replaceState(null, '', currentHash + '?cart=' + tiers);

    }

  }
 
  function updateCart() {

    const n = cart.length;

    document.getElementById('cartCount').textContent = n;

    document.getElementById('cartWidget').classList.toggle('visible', n > 0);

    const badge = document.getElementById('navBadge');

    badge.textContent = n; badge.style.display = n > 0 ? 'flex' : 'none';

    const body = document.getElementById('cartBody');

    const footer = document.getElementById('cartFooter');

    const empty = document.getElementById('cartEmpty');

    if (n === 0) {

      body.innerHTML = ''; body.appendChild(empty); empty.style.display = ''; footer.style.display = 'none';

    } else {

      empty.style.display = 'none'; body.innerHTML = '';

      const bg = {basic:'#e0f2f1',gold:'#fff8e1',platinum:'#e8eaf6'};

      cart.forEach((item,i) => {

        const d = document.createElement('div'); d.className = 'cart-item';

        d.innerHTML = `<div class="cart-item-icon" style="background:${bg[item.tier]||'#f0f0f0'}">${item.icon}</div>
<div class="cart-item-info"><div class="cart-item-name">${item.name}</div><div class="cart-item-price">₹${item.price.toLocaleString('en-IN')} / month</div></div>
<button class="cart-item-remove" onclick="removeFromCart(${i})">✕</button>`;

        body.appendChild(d);

      });

      document.getElementById('cartTotal').textContent = '₹'+cart.reduce((s,i)=>s+i.price,0).toLocaleString('en-IN');

      footer.style.display = '';

    }

  }
 
  function openCart() {

    document.getElementById('cartOverlay').classList.add('open');

    document.getElementById('cartDrawer').classList.add('open');

    document.body.style.overflow='hidden';

    // Reflect cart open state in URL

    const base = window.location.hash.split('?')[0] || '#plans';

    const cartParam = cart.length ? '?cart=' + cart.map(i=>i.tier).join(',') : '';

    history.replaceState(null, '', base + cartParam + (cartParam ? '&drawer=open' : '?drawer=open'));

  }
 
  function closeCart() {

    document.getElementById('cartOverlay').classList.remove('open');

    document.getElementById('cartDrawer').classList.remove('open');

    document.body.style.overflow='';

    // Remove drawer param from URL

    updateCartHash();

  }
 
  function checkout() {

    if (!cart.length) return;

    const names = cart.map(i=>i.name).join(' + ');

    const total = cart.reduce((s,i)=>s+i.price,0);

    alert(`🎉 Thank you, Rajath!\n\nPlan(s): ${names}\nMonthly Total: ₹${total.toLocaleString('en-IN')}\n\nA CCare advisor will contact you shortly to complete enrollment.`);

    cart=[]; updateCart(); closeCart();

    history.replaceState(null, '', '#home');

    showSection('home', true);

  }
 
  function showToast(msg) {

    const t = document.createElement('div');

    t.textContent = msg;

    Object.assign(t.style,{position:'fixed',bottom:'5.5rem',right:'2rem',zIndex:'500',background:'#00695C',color:'#fff',padding:'0.72rem 1.25rem',borderRadius:'100px',fontSize:'0.875rem',fontWeight:'600',fontFamily:'DM Sans,sans-serif',boxShadow:'0 8px 18px rgba(0,0,0,0.16)',animation:'fadeUp 0.3s ease both',pointerEvents:'none'});

    document.body.appendChild(t);

    setTimeout(() => t.remove(), 2400);

  }
 
  // ── Handle hash on page load & browser back/forward ──

  function routeFromHash() {

    const raw   = window.location.hash || '#home';

    const base  = raw.split('?')[0];           // e.g. "#plans"

    const query = raw.includes('?') ? raw.split('?')[1] : '';

    const params = new URLSearchParams(query);
 
    const section = REVERSE_HASH[base] || 'home';

    showSection(section, true);                // skipHash=true so we don't re-write it
 
    // Restore cart items from hash if present

    const cartParam = params.get('cart');

    if (cartParam) {

      const PLAN_MAP = {

        basic:    { name:'Basic Healthcare',    price:2499,  icon:'🌱', tier:'basic'    },

        gold:     { name:'Gold Healthcare',     price:5999,  icon:'✦',  tier:'gold'     },

        platinum: { name:'Platinum Healthcare', price:11499, icon:'💎', tier:'platinum' }

      };

      cart = [];

      cartParam.split(',').forEach(tier => {

        if (PLAN_MAP[tier] && !cart.find(i => i.tier === tier)) {

          cart.push(PLAN_MAP[tier]);

        }

      });

      updateCart();

    }
 
    // Re-open drawer if it was open

    if (params.get('drawer') === 'open') {

      setTimeout(openCart, 300);

    }

  }
 
  window.addEventListener('hashchange', routeFromHash);

  window.addEventListener('DOMContentLoaded', routeFromHash);
 
  // Scroll reveal

  const obs = new IntersectionObserver(entries => { entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); }); }, {threshold:0.1});

  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
